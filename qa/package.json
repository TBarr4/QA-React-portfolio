{
  "name": "qa",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "cy:open": "cypress open --browser chrome",
    "cy:open:electron": "cypress open --browser electron",
    "cy:run": "cypress run --browser chrome",
    "cy:run:smoke": "cypress run --browser chrome --env grepTags=@smoke",
    "cy:run:regression": "cypress run --browser chrome --env grepTags=@regression",
    "cy:run:api": "cypress run --browser chrome --spec 'cypress/api/**/*.cy.ts'",
    "cy:run:api:ci": "cypress run --browser chrome --spec 'cypress/api/**/*.cy.ts' --config baseUrl=null",
    "cy:run:e2e": "cypress run --browser chrome --spec 'cypress/e2e/**/*.cy.ts'",
    "report": "npx mochawesome-merge cypress/results/*.json -o cypress/results/merged-report.json && npx marge cypress/results/merged-report.json -f report -o cypress/reports",
    "clean:reports": "rimraf cypress/results cypress/reports cypress/screenshots cypress/videos",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cypress/grep": "^4.1.0",
    "@types/node": "^22.19.17",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cypress": "^13.16.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "diff": "8.0.3"
  }
}
